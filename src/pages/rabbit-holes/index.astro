---
import IndexLayout from '@/layouts/IndexLayout.astro';
import { getPublishedEntries } from '@/lib/collections';
import { groupIntoClusters } from '@/lib/clusters';

const posts = await getPublishedEntries('rabbit-holes');
const groups = groupIntoClusters('rabbit-holes', posts).map((g) => ({
  id: g.id,
  posts: g.posts.map((p) => ({
    href: `/rabbit-holes/${p.slug}/`,
    title: p.data.title,
  })),
}));
---
<IndexLayout title="rabbit holes" description="grounding ideas in math, papers, and proof." clusters={groups} />
