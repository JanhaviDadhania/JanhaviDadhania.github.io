---
import IndexLayout from '@/layouts/IndexLayout.astro';
import { getPublishedEntries } from '@/lib/collections';
import { groupIntoClusters } from '@/lib/clusters';

const posts = await getPublishedEntries('blog');
const groups = groupIntoClusters('blog', posts).map((g) => ({
  id: g.id,
  posts: g.posts.map((p) => ({
    href: `/blog/${p.slug}/`,
    title: p.data.title,
  })),
}));
---
<IndexLayout title="blog" description="long-form posts." clusters={groups} />
