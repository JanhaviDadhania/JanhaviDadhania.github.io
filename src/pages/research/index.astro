---
import IndexLayout from '@/layouts/IndexLayout.astro';
import { getPublishedEntries } from '@/lib/collections';
import { groupIntoClusters } from '@/lib/clusters';

const posts = await getPublishedEntries('research');
const groups = groupIntoClusters('research', posts).map((g) => ({
  id: g.id,
  posts: g.posts.map((p) => ({
    href: `/research/${p.slug}/`,
    title: p.data.title,
  })),
}));
---
<IndexLayout title="research" description="grounding ideas in math, papers, and proof." clusters={groups} />
