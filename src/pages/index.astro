---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import { site } from '@/site.config';
import { getCollection, type CollectionEntry } from 'astro:content';

type FeaturedCollection = 'blog' | 'research' | 'data' | 'fantasy' | 'tools';
type AnyEntry = CollectionEntry<FeaturedCollection>;

const visibleFilter = ({ data }: { data: { draft: boolean } }) => !data.draft;

// Resolve featured entries from site.config.ts in the order they're listed.
// Each entry is '<collection>/<slug>'. Tools are mixed in alongside blog/
// research/data/fantasy posts so the home page order is fully explicit.
const TOTAL_LINES = 8;
const wanted = site.featured.slice(0, TOTAL_LINES);
const collectionsNeeded = new Set(
  wanted.map((s) => s.split('/')[0]).filter(Boolean) as FeaturedCollection[],
);

const lookup = new Map<string, AnyEntry>();
await Promise.all(
  Array.from(collectionsNeeded).map(async (col) => {
    const entries = await getCollection(col, visibleFilter);
    for (const entry of entries) {
      lookup.set(`${entry.collection}/${entry.slug}`, entry as AnyEntry);
    }
  }),
);

interface JournalLine {
  href: string;
  title: string;
  label: string;
}

const journalLines: JournalLine[] = wanted
  .map((key) => lookup.get(key))
  .filter((e): e is AnyEntry => e !== undefined)
  .map((entry) => ({
    href: `/${entry.collection}/${entry.slug}/`,
    title: entry.data.title,
    label: entry.collection,
  }));

---
<BaseLayout>
  <main class="container">
    <Hero />

    <section class="journal">
      {journalLines.map((line) => (
        <a class="journal-line" href={line.href}>
          <span class="journal-text">
            <span class="journal-label">[{line.label}]</span>
            {' '}{line.title}
          </span>
        </a>
      ))}
    </section>

    <section class="substack" id="substack-section" hidden>
      <h2 class="substack-heading">from substack</h2>
      <ul class="substack-list" id="substack-list"></ul>
    </section>
  </main>
</BaseLayout>

<script is:inline>
  (async () => {
    const FEED = 'https://janhavidadhania.substack.com/feed';
    const PROXIES = [
      (u) => 'https://api.allorigins.win/raw?url=' + encodeURIComponent(u),
      (u) => 'https://corsproxy.io/?' + encodeURIComponent(u),
    ];

    async function loadXml() {
      for (const build of PROXIES) {
        try {
          const res = await fetch(build(FEED), { cache: 'no-store' });
          if (!res.ok) continue;
          const text = await res.text();
          if (text && text.includes('<item')) return text;
        } catch {}
      }
      return null;
    }

    const xml = await loadXml();
    if (!xml) return;

    const doc = new DOMParser().parseFromString(xml, 'text/xml');
    const items = Array.from(doc.querySelectorAll('item')).slice(0, 20);
    if (!items.length) return;

    const list = document.getElementById('substack-list');
    const section = document.getElementById('substack-section');
    if (!list || !section) return;

    const dateFmt = new Intl.DateTimeFormat('en-US', {
      month: 'short', day: 'numeric', year: 'numeric',
    });

    for (const item of items) {
      const title = item.querySelector('title')?.textContent?.trim() ?? '';
      const link = item.querySelector('link')?.textContent?.trim() ?? '';
      const pubDate = item.querySelector('pubDate')?.textContent?.trim() ?? '';
      if (!title || !link) continue;

      const li = document.createElement('li');
      li.className = 'substack-item';
      const a = document.createElement('a');
      a.className = 'substack-link';
      a.href = link;
      a.target = '_blank';
      a.rel = 'noopener noreferrer';
      const titleSpan = document.createElement('span');
      titleSpan.className = 'substack-title';
      titleSpan.textContent = title;
      const dateSpan = document.createElement('span');
      dateSpan.className = 'substack-date';
      if (pubDate) {
        const d = new Date(pubDate);
        if (!isNaN(d.getTime())) dateSpan.textContent = dateFmt.format(d);
      }
      a.appendChild(titleSpan);
      a.appendChild(dateSpan);
      li.appendChild(a);
      list.appendChild(li);
    }

    section.hidden = false;
  })();
</script>

<style>
  .container {
    width: 90%;
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 10vh 0;
    flex: 1;
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .journal {
    margin-top: var(--space-12);
    max-width: var(--content-max);
    position: relative;
  }
  .journal::before {
    content: "";
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    width: 1px;
    background: var(--rule-faint);
    z-index: 0;
  }

  .journal-line {
    border-bottom: 1px solid var(--rule);
    height: 3rem;
    display: flex;
    align-items: flex-end;
    padding: 0 0 0.3rem 1rem;
    text-decoration: none;
    color: inherit;
  }
  .journal-text {
    font-family: var(--font-script);
    font-style: italic;
    font-size: 1.6rem;
    color: #2a2a2a;
    letter-spacing: 0.01em;
  }
  .journal-label {
    color: var(--ink-faded);
    margin-right: 0.3rem;
  }

  .substack {
    margin-top: 3rem;
    max-width: var(--content-max);
  }
  .substack-heading {
    font-family: var(--font-serif);
    font-size: 2.5rem;
    font-weight: 400;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    line-height: 1.1;
    color: var(--ink);
    margin: 0 0 var(--space-4) 0;
  }
  .substack-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  :global(.substack-item) {
    border-bottom: 1px solid var(--rule);
  }
  :global(.substack-link) {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.75rem 0;
    text-decoration: none;
    color: inherit;
  }
  :global(.substack-link:hover .substack-title) {
    text-decoration: underline;
  }
  :global(.substack-title) {
    font-family: var(--font-script);
    font-style: italic;
    font-size: 1.4rem;
    color: #2a2a2a;
    letter-spacing: 0.01em;
  }
  :global(.substack-date) {
    font-size: 0.85rem;
    color: var(--ink-faded);
    white-space: nowrap;
    flex-shrink: 0;
  }
</style>
