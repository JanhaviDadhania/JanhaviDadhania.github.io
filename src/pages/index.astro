---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import { site } from '@/site.config';
import { getCollection, type CollectionEntry } from 'astro:content';

type FeaturedCollection = 'blog' | 'research' | 'data' | 'fantasy';
type AnyPost = CollectionEntry<FeaturedCollection>;

const visibleFilter = ({ data }: { data: { draft: boolean } }) => !data.draft;

// Resolve featured slugs from site.config.ts → actual post entries.
// Slugs that don't match a published post are silently dropped.
const TOTAL_LINES = 8;
const wanted = site.featured_slugs.slice(0, TOTAL_LINES);
const collectionsNeeded = new Set(
  wanted.map((s) => s.split('/')[0]).filter(Boolean) as FeaturedCollection[],
);

const lookup = new Map<string, AnyPost>();
await Promise.all(
  Array.from(collectionsNeeded).map(async (col) => {
    const entries = await getCollection(col, visibleFilter);
    for (const entry of entries) {
      lookup.set(`${entry.collection}/${entry.slug}`, entry as AnyPost);
    }
  }),
);

const featured: AnyPost[] = wanted
  .map((s) => lookup.get(s))
  .filter((p): p is AnyPost => p !== undefined);

// Resolve featured tools.
const toolsEntries = await getCollection('tools', visibleFilter);
const toolsBySlug = new Map(toolsEntries.map((t) => [t.slug, t]));
const featuredTools = site.featured_tools
  .map((slug) => toolsBySlug.get(slug))
  .filter((t): t is CollectionEntry<'tools'> => t !== undefined);

// Merge blog/research/data/fantasy entries and tools into a single
// flat list of journal lines, each tagged with its collection so we
// can prefix the title with [collection] on the home page.
interface JournalLine {
  href: string;
  title: string;
  label: string;
}

const journalLines: JournalLine[] = [
  ...featured.map((post) => ({
    href: `/${post.collection}/${post.slug}/`,
    title: post.data.title,
    label: post.collection,
  })),
  ...featuredTools.map((tool) => ({
    href: `/tools/${tool.slug}/`,
    title: tool.data.title,
    label: 'tools',
  })),
];

const emptyLines = Math.max(0, TOTAL_LINES - journalLines.length);
---
<BaseLayout>
  <main class="container">
    <Hero />

    <section class="journal">
      {journalLines.map((line) => (
        <a class="journal-line" href={line.href}>
          <span class="journal-text">
            <span class="journal-label">[{line.label}]</span>
            {' '}{line.title}
          </span>
        </a>
      ))}
      {Array.from({ length: emptyLines }).map(() => (
        <div class="journal-line empty"></div>
      ))}
    </section>
  </main>
</BaseLayout>

<style>
  .container {
    width: 90%;
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 10vh 0;
    flex: 1;
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .journal {
    margin-top: var(--space-12);
    max-width: var(--content-max);
    position: relative;
  }
  .journal::before {
    content: "";
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    width: 1px;
    background: var(--rule-faint);
    z-index: 0;
  }

  .journal-line {
    border-bottom: 1px solid var(--rule);
    height: 3rem;
    display: flex;
    align-items: flex-end;
    padding: 0 0 0.3rem 1rem;
    text-decoration: none;
    color: inherit;
  }
  .journal-line.empty { pointer-events: none; }

  .journal-text {
    font-family: var(--font-script);
    font-size: 1.8rem;
    color: #2a2a2a;
    letter-spacing: 0.02em;
  }
  .journal-label {
    color: var(--ink-faded);
    margin-right: 0.3rem;
  }
</style>
