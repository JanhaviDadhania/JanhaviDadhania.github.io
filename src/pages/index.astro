---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import { site } from '@/site.config';
import { getCollection, type CollectionEntry } from 'astro:content';

type AnyPost =
  | CollectionEntry<'blog'>
  | CollectionEntry<'research'>
  | CollectionEntry<'data'>
  | CollectionEntry<'fantasy'>;

const visibleFilter = ({ data }: { data: { draft: boolean } }) => !data.draft;

const [blogPosts, researchPosts, dataPosts, fantasyPosts] = await Promise.all([
  getCollection('blog', visibleFilter),
  getCollection('research', visibleFilter),
  getCollection('data', visibleFilter),
  getCollection('fantasy', visibleFilter),
]);

const allPosts: AnyPost[] = [
  ...blogPosts,
  ...researchPosts,
  ...dataPosts,
  ...fantasyPosts,
];
allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const featured = site.featured_slug
  ? allPosts.find((p) => `${p.collection}/${p.slug}` === site.featured_slug) ?? null
  : null;

const recent = allPosts.filter((p) => p !== featured).slice(0, 7);
---
<BaseLayout>
  <main class="container">
    <Hero />

    <section class="journal">
      {featured && (
        <a class="journal-line featured" href={`/${featured.collection}/${featured.slug}/`}>
          <span class="journal-text">{featured.data.title}</span>
        </a>
      )}
      {recent.map((post) => (
        <a class="journal-line" href={`/${post.collection}/${post.slug}/`}>
          <span class="journal-text">{post.data.title}</span>
        </a>
      ))}
      {Array.from({ length: Math.max(0, 8 - (recent.length + (featured ? 1 : 0))) }).map(() => (
        <div class="journal-line empty"></div>
      ))}
    </section>
  </main>
</BaseLayout>

<style>
  .container {
    width: 90%;
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 10vh 0;
    flex: 1;
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .journal {
    margin-top: var(--space-12);
    max-width: var(--content-max);
    position: relative;
  }
  .journal::before {
    content: "";
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    width: 1px;
    background: var(--rule-faint);
    z-index: 0;
  }

  .journal-line {
    border-bottom: 1px solid var(--rule);
    height: 3rem;
    display: flex;
    align-items: flex-end;
    padding: 0 0 0.3rem 1rem;
    text-decoration: none;
    color: inherit;
  }
  .journal-line.empty { pointer-events: none; }

  .journal-text {
    font-family: var(--font-script);
    font-size: 1.8rem;
    color: #2a2a2a;
    letter-spacing: 0.02em;
  }

  .featured .journal-text {
    font-weight: 700;
  }
</style>
