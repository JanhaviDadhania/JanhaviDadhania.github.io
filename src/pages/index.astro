---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import { site } from '@/site.config';
import { getCollection, type CollectionEntry } from 'astro:content';

type FeaturedCollection = 'blog' | 'research' | 'data' | 'fantasy' | 'tools';
type AnyEntry = CollectionEntry<FeaturedCollection>;

const visibleFilter = ({ data }: { data: { draft: boolean } }) => !data.draft;

// Resolve featured entries from site.config.ts in the order they're listed.
// Each entry is '<collection>/<slug>'. Tools are mixed in alongside blog/
// research/data/fantasy posts so the home page order is fully explicit.
const TOTAL_LINES = 8;
const wanted = site.featured.slice(0, TOTAL_LINES);
const collectionsNeeded = new Set(
  wanted.map((s) => s.split('/')[0]).filter(Boolean) as FeaturedCollection[],
);

const lookup = new Map<string, AnyEntry>();
await Promise.all(
  Array.from(collectionsNeeded).map(async (col) => {
    const entries = await getCollection(col, visibleFilter);
    for (const entry of entries) {
      lookup.set(`${entry.collection}/${entry.slug}`, entry as AnyEntry);
    }
  }),
);

interface JournalLine {
  href: string;
  title: string;
  label: string;
}

const journalLines: JournalLine[] = wanted
  .map((key) => lookup.get(key))
  .filter((e): e is AnyEntry => e !== undefined)
  .map((entry) => ({
    href: `/${entry.collection}/${entry.slug}/`,
    title: entry.data.title,
    label: entry.collection,
  }));

const emptyLines = Math.max(0, TOTAL_LINES - journalLines.length);
---
<BaseLayout>
  <main class="container">
    <Hero />

    <section class="journal">
      {journalLines.map((line) => (
        <a class="journal-line" href={line.href}>
          <span class="journal-text">
            <span class="journal-label">[{line.label}]</span>
            {' '}{line.title}
          </span>
        </a>
      ))}
      {Array.from({ length: emptyLines }).map(() => (
        <div class="journal-line empty"></div>
      ))}
    </section>
  </main>
</BaseLayout>

<style>
  .container {
    width: 90%;
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 10vh 0;
    flex: 1;
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .journal {
    margin-top: var(--space-12);
    max-width: var(--content-max);
    position: relative;
  }
  .journal::before {
    content: "";
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    width: 1px;
    background: var(--rule-faint);
    z-index: 0;
  }

  .journal-line {
    border-bottom: 1px solid var(--rule);
    height: 3rem;
    display: flex;
    align-items: flex-end;
    padding: 0 0 0.3rem 1rem;
    text-decoration: none;
    color: inherit;
  }
  .journal-line.empty { pointer-events: none; }

  .journal-text {
    font-family: var(--font-script);
    font-style: italic;
    font-size: 1.6rem;
    color: #2a2a2a;
    letter-spacing: 0.01em;
  }
  .journal-label {
    color: var(--ink-faded);
    margin-right: 0.3rem;
  }
</style>
