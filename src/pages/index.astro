---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import { site } from '@/site.config';
import { getCollection, type CollectionEntry } from 'astro:content';

type FeaturedCollection = 'blog' | 'research' | 'data' | 'fantasy';
type AnyPost = CollectionEntry<FeaturedCollection>;

const visibleFilter = ({ data }: { data: { draft: boolean } }) => !data.draft;

// Resolve featured slugs from site.config.ts → actual post entries.
// Slugs that don't match a published post are silently dropped.
const TOTAL_LINES = 8;
const wanted = site.featured_slugs.slice(0, TOTAL_LINES);
const collectionsNeeded = new Set(
  wanted.map((s) => s.split('/')[0]).filter(Boolean) as FeaturedCollection[],
);

const lookup = new Map<string, AnyPost>();
await Promise.all(
  Array.from(collectionsNeeded).map(async (col) => {
    const entries = await getCollection(col, visibleFilter);
    for (const entry of entries) {
      lookup.set(`${entry.collection}/${entry.slug}`, entry as AnyPost);
    }
  }),
);

const featured: AnyPost[] = wanted
  .map((s) => lookup.get(s))
  .filter((p): p is AnyPost => p !== undefined);

const emptyLines = Math.max(0, TOTAL_LINES - featured.length);

// Resolve featured tools.
const toolsEntries = await getCollection('tools', visibleFilter);
const toolsBySlug = new Map(toolsEntries.map((t) => [t.slug, t]));
const featuredTools = site.featured_tools
  .map((slug) => toolsBySlug.get(slug))
  .filter((t): t is CollectionEntry<'tools'> => t !== undefined);
---
<BaseLayout>
  <main class="container">
    <Hero />

    <section class="journal">
      {featured.map((post) => (
        <a class="journal-line" href={`/${post.collection}/${post.slug}/`}>
          <span class="journal-text">{post.data.title}</span>
        </a>
      ))}
      {Array.from({ length: emptyLines }).map(() => (
        <div class="journal-line empty"></div>
      ))}
    </section>

    {featuredTools.length > 0 && (
      <section class="tools-strip" aria-labelledby="tools-heading">
        <h2 id="tools-heading" class="tools-heading">tools</h2>
        <ul class="tools-list">
          {featuredTools.map((tool) => (
            <li>
              <a class="tools-link" href={`/tools/${tool.slug}/`}>
                <span class="tools-name">{tool.data.title}</span>
                {tool.data.summary && (
                  <span class="tools-summary"> — {tool.data.summary}</span>
                )}
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}
  </main>
</BaseLayout>

<style>
  .container {
    width: 90%;
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 10vh 0;
    flex: 1;
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .journal {
    margin-top: var(--space-12);
    max-width: var(--content-max);
    position: relative;
  }
  .journal::before {
    content: "";
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    width: 1px;
    background: var(--rule-faint);
    z-index: 0;
  }

  .journal-line {
    border-bottom: 1px solid var(--rule);
    height: 3rem;
    display: flex;
    align-items: flex-end;
    padding: 0 0 0.3rem 1rem;
    text-decoration: none;
    color: inherit;
  }
  .journal-line.empty { pointer-events: none; }

  .journal-text {
    font-family: var(--font-script);
    font-size: 1.8rem;
    color: #2a2a2a;
    letter-spacing: 0.02em;
  }

  .tools-strip {
    margin-top: var(--space-12);
    max-width: var(--content-max);
  }
  .tools-heading {
    font-family: var(--font-serif);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: var(--ink-faded);
    font-weight: 400;
    margin: 0 0 var(--space-3);
  }
  .tools-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .tools-link {
    color: var(--ink);
    text-decoration: none;
    font-family: var(--font-serif);
    font-size: 1.05rem;
  }
  .tools-name {
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }
  .tools-summary {
    color: var(--ink-faded);
    font-style: italic;
  }
  .tools-link:hover .tools-name { opacity: 0.6; }
</style>
