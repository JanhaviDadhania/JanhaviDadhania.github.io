---
import IndexLayout from '@/layouts/IndexLayout.astro';
import { getPublishedEntries } from '@/lib/collections';
import { groupIntoClusters } from '@/lib/clusters';

const tools = await getPublishedEntries('tools');
const groups = groupIntoClusters('tools', tools).map((g) => ({
  id: g.id,
  posts: g.posts.map((p) => ({
    href: `/tools/${p.slug}/`,
    title: p.data.title,
  })),
}));
---
<IndexLayout title="tools" description="things i made or use." clusters={groups} />
