---
import ToolLayout from '@/layouts/ToolLayout.astro';
import { toolComponents } from '@/lib/toolComponents';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const tools = await getCollection('tools');
  return tools.map((tool) => ({
    params: { slug: tool.slug },
    props: { tool },
  }));
}

interface Props {
  tool: CollectionEntry<'tools'>;
}

const { tool } = Astro.props;
const { Content } = await tool.render();
---
<ToolLayout
  slug={`${tool.collection}/${tool.slug}`}
  title={tool.data.title}
  date={tool.data.date}
  summary={tool.data.summary}
  category={tool.data.category}
  link={tool.data.link}
>
  <Content components={toolComponents} />
</ToolLayout>
