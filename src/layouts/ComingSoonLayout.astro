---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title?: string;
  message?: string;
}

const { title = 'Coming Soon', message = 'This page is on its way.' } = Astro.props;
---
<BaseLayout title={title}>
  <main class="coming-soon">
    <h1>{title}</h1>
    <p>{message}</p>
    <a href="/" class="home-link">← back to The Mirror</a>
  </main>
</BaseLayout>

<style>
  .coming-soon {
    width: 90%;
    max-width: 600px;
    margin: 0 auto;
    padding: 20vh 0;
    text-align: center;
  }
  h1 {
    font-family: var(--font-serif);
    font-size: 3rem;
    margin: 0 0 var(--space-3);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  p {
    color: var(--ink-faded);
    font-style: italic;
    margin: 0 0 var(--space-6);
  }
  .home-link {
    font-family: var(--font-serif);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid var(--rule);
    padding-bottom: 2px;
  }
</style>
