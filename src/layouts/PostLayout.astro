---
import BaseLayout from './BaseLayout.astro';
import PostMeta from '@/components/PostMeta.astro';
import BackLink from '@/components/BackLink.astro';

interface Props {
  title: string;
  date: Date;
  tags?: readonly string[];
  summary?: string;
  meta: {
    on_coffee: boolean;
    is_finished: boolean;
    opinion_strength: number;
    evidence_strength: number;
  };
}

// `tags` is intentionally accepted in the props (schema requires it) but not
// rendered on the post page — it's used for indexes and previews only.
const { title, summary, meta } = Astro.props;

// Random horizontal margin per post: 50px base + 1..100px jitter on each side.
// Evaluated at build time, so the value is stable for a given build but
// different across posts. Re-randomises whenever the site rebuilds.
const leftMargin = 50 + Math.floor(Math.random() * 100) + 1;
const rightMargin = 50 + Math.floor(Math.random() * 100) + 1;
---
<BaseLayout title={title} description={summary}>
  <article class="post" style={`padding-left: ${leftMargin}px; padding-right: ${rightMargin}px;`}>
    <header class="post-header">
      <h1 class="post-title">{title}</h1>
      <div class="post-meta-wrap">
        <PostMeta meta={meta} />
      </div>
    </header>

    <div class="post-body">
      <slot />
    </div>
  </article>
  <BackLink />
</BaseLayout>

<style is:global>
  /* Full-viewport graph paper background, only on post pages.
     Scoped via the .post wrapper so non-post pages stay plain. */
  body:has(.post) {
    background-color: var(--paper);
    background-image:
      linear-gradient(to right,  rgba(120, 0, 0, 0.07) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(120, 0, 0, 0.07) 1px, transparent 1px);
    background-size: 14px 14px;
  }
</style>

<style>
  .post {
    width: 100%;
    padding: var(--space-4) var(--space-4) 6rem;
    box-sizing: border-box;
    font-family: var(--font-grotezk);
  }

  .post-header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: end;
    gap: 0 var(--space-6);
    padding-bottom: var(--space-2);
    margin-bottom: var(--space-4);
    /* Faint red horizontal rule below the header — references the graph paper */
    border-bottom: 1px solid var(--rule-faint);
  }

  .post-title {
    font-family: var(--font-grotezk);
    font-size: 3rem;
    font-weight: 400;
    line-height: 1.05;
    margin: 0;
    align-self: end;
  }

  /* Vertical rule between title and meta block */
  .post-meta-wrap {
    border-left: 1px solid var(--rule-faint);
    padding-left: var(--space-4);
    align-self: end;
  }

  .post-body :global(p) {
    margin: 0 0 0.4rem;
  }

  .post-body :global(p:last-child) {
    margin-bottom: 0;
  }

  /* Footnotes section — sits at the end of body */
  .post-body :global(h2) {
    font-family: var(--font-serif);
    font-size: 1.4rem;
    font-weight: 500;
    margin-top: var(--space-6);
    margin-bottom: var(--space-2);
  }

  @media (max-width: 800px) {
    .post-header {
      grid-template-columns: 1fr;
      gap: var(--space-3) 0;
      align-items: start;
    }
    .post-title { font-size: 2rem; }
    .post-meta-wrap {
      border-left: none;
      padding-left: 0;
      padding-top: var(--space-2);
      border-top: 1px solid var(--rule-faint);
    }
  }
</style>
