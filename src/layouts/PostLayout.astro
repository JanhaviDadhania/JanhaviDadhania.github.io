---
import BaseLayout from './BaseLayout.astro';
import BackLink from '@/components/BackLink.astro';
import UnfinishedBar from '@/components/UnfinishedBar.astro';
import { site } from '@/site.config';

interface Props {
  /** '<collection>/<slug>' — used to look up unfinished status in site config. */
  slug: string;
  title: string;
  date: Date;
  tags?: readonly string[];
  summary?: string;
  side_images?: string[];
  co_author?: { name: string; url?: string };
  meta: {
    is_finished: boolean;
    opinion_strength: number;
    evidence_strength: number;
  };
}

// `tags` and `meta` are accepted in the props (schema requires them) but not
// rendered on the post page right now — the meta block was removed per janhavi
// (2026-05-24); keeping the fields in frontmatter so the area can be restored.
const { slug, title, summary, side_images, co_author } = Astro.props;

const isUnfinished = site.unfinished_slugs.includes(slug);

// Random horizontal margin per post: 50px base + 1..100px jitter on each side.
// Evaluated at build time, so the value is stable for a given build but
// different across posts. Re-randomises whenever the site rebuilds.
const leftMargin = 50 + Math.floor(Math.random() * 100) + 1;
const rightMargin = 50 + Math.floor(Math.random() * 100) + 1;
---
<BaseLayout title={title} description={summary}>
  <article
    class="post"
    data-side-images={side_images && side_images.length > 0 ? '' : undefined}
    style={`--left-margin: ${leftMargin}px; --right-margin: ${rightMargin}px;`}
  >
    {isUnfinished && <UnfinishedBar />}
    <header class="post-header">
      <h1 class="post-title">{title}</h1>
      <div class="post-meta-wrap">
        {co_author && (
          <p class="co-author">
            with{' '}
            {co_author.url
              ? <a href={co_author.url} target="_blank" rel="noopener noreferrer">{co_author.name}</a>
              : co_author.name}
          </p>
        )}
      </div>
    </header>

    <div class="post-body">
      <slot />
    </div>
  </article>

  {side_images && side_images.length > 0 && (
    <aside class="side-images" aria-label="reference images for this post">
      {side_images.map((src) => (
        <img src={src} alt="" loading="lazy" />
      ))}
    </aside>
  )}

  <BackLink />
</BaseLayout>

<style is:global>
  /* Full-viewport graph paper background, only on post pages.
     Scoped via the .post wrapper so non-post pages stay plain. */
  body:has(.post) {
    background-color: var(--paper);
    background-image:
      linear-gradient(to right,  rgba(120, 0, 0, 0.07) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(120, 0, 0, 0.07) 1px, transparent 1px);
    background-size: 14px 14px;
  }
</style>

<style>
  /* The .post element is full-viewport-width with NO top/horizontal
     padding — so the rules in the post-header touch the page edges and
     each other without any gaps. Per-post random margins live only on
     the inner content elements (title, meta-wrap, body). */
  .post {
    position: relative;          /* anchor for the Arrow SVG overlay */
    width: 100%;
    padding: 0 0 6rem;
    box-sizing: border-box;
    font-family: var(--font-grotezk);
  }

  .post-header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: stretch;            /* meta-wrap fills full row height */
    gap: 0;
    margin-bottom: var(--space-4);
    /* Horizontal rule under the title — full-viewport width, sits flush
       with the bottom of the grid row (no padding-bottom on header). */
    border-bottom: 2px solid var(--ink);
  }

  .post-title {
    font-family: var(--font-grotezk);
    font-size: 3rem;
    font-weight: 400;
    line-height: 1.05;
    margin: 0;
    align-self: end;
    padding-left: var(--left-margin);
    padding-right: var(--space-4);
    padding-top: var(--space-6);     /* breathing room above title */
    padding-bottom: var(--space-2);  /* gap above horizontal rule */
  }

  /* Vertical rule between title and meta — spans the full row height,
     touching the top of the page and the horizontal rule below. */
  .post-meta-wrap {
    border-left: 2px solid var(--ink);
    padding-left: var(--space-4);
    padding-right: var(--right-margin);
    padding-top: var(--space-4);     /* meta content not glued to viewport top */
    padding-bottom: var(--space-2);
    display: flex;
    align-items: flex-end;           /* keep meta content visually at bottom */
  }

  .co-author {
    margin: 0;
    font-size: 0.85rem;
    font-family: var(--font-grotezk);
    opacity: 0.7;
  }
  .co-author a {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .post-body {
    padding-left: var(--left-margin);
    padding-right: var(--right-margin);
  }

  .post-body :global(p) { margin: 0 0 0.4rem; }
  .post-body :global(p:last-child) { margin-bottom: 0; }

  /* Footnotes section — sits at the end of body */
  .post-body :global(h2) {
    font-family: var(--font-serif);
    font-size: 1.4rem;
    font-weight: 500;
    margin-top: var(--space-6);
    margin-bottom: var(--space-2);
  }

  @media (max-width: 800px) {
    .post-header {
      grid-template-columns: 1fr;
      gap: var(--space-3) 0;
      align-items: start;
    }
    .post-title {
      font-size: 2rem;
      padding-right: var(--right-margin);
    }
    .post-meta-wrap {
      border-left: none;
      padding-left: var(--left-margin);
      padding-top: var(--space-2);
      border-top: 2px solid var(--ink);
    }
  }

  /* ─── side_images column ─────────────────────────────────────────────── */
  /* Fixed-position right column at 30% viewport width, vertically scrollable,
     stacked images. The article body shrinks to clear it (right edge stops at
     the column). Only on viewports wider than the mobile breakpoint. */
  .side-images {
    position: fixed;
    top: 0;
    right: 0;
    width: 30vw;
    height: 100vh;
    overflow-y: auto;
    padding: 1rem 1rem 6rem;
    box-sizing: border-box;
    background-color: var(--paper);
    border-left: 2px solid var(--ink);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    z-index: 5;
  }
  .side-images img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* When the post has side_images, push the post content off the right 30%
     so it doesn't slip under the fixed column. Header and body both shift. */
  .post[data-side-images] .post-header,
  .post[data-side-images] .post-body {
    margin-right: 30vw;
  }
  /* The header's bottom rule should also stop at the column. */
  .post[data-side-images] {
    overflow: hidden;
  }

  @media (max-width: 800px) {
    /* On small screens the side column is collapsed to inline at the bottom,
       not a fixed sidebar — phone users don't have the horizontal room. */
    .side-images {
      position: static;
      width: 100%;
      height: auto;
      border-left: none;
      border-top: 2px solid var(--ink);
      padding: 1rem var(--left-margin) 2rem var(--left-margin);
    }
    .post[data-side-images] .post-header,
    .post[data-side-images] .post-body {
      margin-right: 0;
    }
  }
</style>
