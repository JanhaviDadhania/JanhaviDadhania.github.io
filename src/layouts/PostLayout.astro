---
import BaseLayout from './BaseLayout.astro';
import PostMeta from '@/components/PostMeta.astro';
import BackLink from '@/components/BackLink.astro';

interface Props {
  title: string;
  date: Date;
  tags?: readonly string[];
  summary?: string;
  meta: {
    on_coffee: boolean;
    is_finished: boolean;
    opinion_strength: number;
    evidence_strength: number;
  };
}

// `tags` is intentionally accepted in the props (schema requires it) but not
// rendered on the post page — it's used for indexes and previews only.
const { title, summary, meta } = Astro.props;

// Random horizontal margin per post: 50px base + 1..100px jitter on each side.
// Evaluated at build time, so the value is stable for a given build but
// different across posts. Re-randomises whenever the site rebuilds.
const leftMargin = 50 + Math.floor(Math.random() * 100) + 1;
const rightMargin = 50 + Math.floor(Math.random() * 100) + 1;
---
<BaseLayout title={title} description={summary}>
  <article
    class="post"
    style={`--left-margin: ${leftMargin}px; --right-margin: ${rightMargin}px;`}
  >
    <header class="post-header">
      <h1 class="post-title">{title}</h1>
      <div class="post-meta-wrap">
        <PostMeta meta={meta} />
      </div>
    </header>

    <div class="post-body">
      <slot />
    </div>
  </article>
  <BackLink />
</BaseLayout>

<style is:global>
  /* Full-viewport graph paper background, only on post pages.
     Scoped via the .post wrapper so non-post pages stay plain. */
  body:has(.post) {
    background-color: var(--paper);
    background-image:
      linear-gradient(to right,  rgba(120, 0, 0, 0.07) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(120, 0, 0, 0.07) 1px, transparent 1px);
    background-size: 14px 14px;
  }
</style>

<style>
  /* The .post element is full-viewport-width with NO top/horizontal
     padding — so the rules in the post-header touch the page edges and
     each other without any gaps. Per-post random margins live only on
     the inner content elements (title, meta-wrap, body). */
  .post {
    width: 100%;
    padding: 0 0 6rem;
    box-sizing: border-box;
    font-family: var(--font-grotezk);
  }

  .post-header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: stretch;            /* meta-wrap fills full row height */
    gap: 0;
    margin-bottom: var(--space-4);
    /* Horizontal rule under the title — full-viewport width, sits flush
       with the bottom of the grid row (no padding-bottom on header). */
    border-bottom: 2px solid var(--ink);
  }

  .post-title {
    font-family: var(--font-grotezk);
    font-size: 3rem;
    font-weight: 400;
    line-height: 1.05;
    margin: 0;
    align-self: end;
    padding-left: var(--left-margin);
    padding-right: var(--space-4);
    padding-top: var(--space-6);     /* breathing room above title */
    padding-bottom: var(--space-2);  /* gap above horizontal rule */
  }

  /* Vertical rule between title and meta — spans the full row height,
     touching the top of the page and the horizontal rule below. */
  .post-meta-wrap {
    border-left: 2px solid var(--ink);
    padding-left: var(--space-4);
    padding-right: var(--right-margin);
    padding-top: var(--space-4);     /* meta content not glued to viewport top */
    padding-bottom: var(--space-2);
    display: flex;
    align-items: flex-end;           /* keep meta content visually at bottom */
  }

  .post-body {
    padding-left: var(--left-margin);
    padding-right: var(--right-margin);
  }

  .post-body :global(p) { margin: 0 0 0.4rem; }
  .post-body :global(p:last-child) { margin-bottom: 0; }

  /* Footnotes section — sits at the end of body */
  .post-body :global(h2) {
    font-family: var(--font-serif);
    font-size: 1.4rem;
    font-weight: 500;
    margin-top: var(--space-6);
    margin-bottom: var(--space-2);
  }

  @media (max-width: 800px) {
    .post-header {
      grid-template-columns: 1fr;
      gap: var(--space-3) 0;
      align-items: start;
    }
    .post-title {
      font-size: 2rem;
      padding-right: var(--right-margin);
    }
    .post-meta-wrap {
      border-left: none;
      padding-left: var(--left-margin);
      padding-top: var(--space-2);
      border-top: 2px solid var(--ink);
    }
  }
</style>
