---
import BaseLayout from './BaseLayout.astro';
import BackLink from '@/components/BackLink.astro';

interface ClusterItem {
  href: string;
  title: string;
}

interface Cluster {
  id: string;
  posts: ClusterItem[];
}

interface Props {
  /** The collection name shown as the giant bottom-left heading. */
  title: string;
  /** Pre-grouped clusters of posts. Empty array → just title, nothing else. */
  clusters: Cluster[];
  description?: string;
}

const { title, clusters, description } = Astro.props;
---
<BaseLayout title={title} description={description}>
  <main class="index-page">
    {clusters.length > 0 && (
      <div class="clusters">
        {clusters.map((cluster) => (
          <div class="cluster">
            {cluster.posts.map((post, i) => (
              <div class={`item ${i % 2 === 0 ? 'item--zig' : 'item--zag'}`}>
                <a class="item-link" href={post.href}>{post.title}</a>
              </div>
            ))}
          </div>
        ))}
      </div>
    )}

    <h1 class="index-title">{title}</h1>
  </main>
  <BackLink />
</BaseLayout>

<style is:global>
  /* Full-viewport dotted grid background — only on collection index pages.
     Scoped via the .index-page wrapper so post pages keep their line grid
     and other pages stay plain. */
  body:has(.index-page) {
    background-color: var(--paper);
    background-image: radial-gradient(
      circle,
      rgba(120, 0, 0, 0.18) 1px,
      transparent 1px
    );
    background-size: 18px 18px;
  }
</style>

<style>
  .index-page {
    position: relative;
    min-height: 100vh;
    width: 100%;
    padding: var(--space-6) var(--space-6) calc(var(--space-12) + 6rem);
    box-sizing: border-box;
    font-family: var(--font-grotezk);
  }

  /* ─── Clusters at top ───────────────────────────────────────────── */
  .clusters {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-6) var(--space-12);
    align-items: flex-start;
    margin-top: 2vh;
    padding-left: 4vw;
  }

  .cluster {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  /* Each item is a single-column box; titles wrap inside. */
  .item {
    --item-width: 180px;
    --zigzag-shift: 30px;
    width: var(--item-width);
    max-width: var(--item-width);
  }

  .item--zig { margin-left: 0; }
  .item--zag { margin-left: var(--zigzag-shift); }

  .item-link {
    font-family: var(--font-grotezk);
    font-size: 0.9rem;
    line-height: 1.25;
    color: var(--ink);
    text-decoration: none;
    display: block;
  }
  .item-link:hover { opacity: 0.6; }

  /* ─── Big bottom-left title ─────────────────────────────────────── */
  .index-title {
    position: absolute;
    left: 4vw;
    bottom: 6vh;
    margin: 0;
    font-family: var(--font-grotezk);
    font-weight: 400;
    font-size: clamp(4rem, 12vw, 9rem);
    line-height: 0.9;
    letter-spacing: -0.02em;
    color: var(--ink);
    text-transform: lowercase;
    pointer-events: none;
  }

  @media (max-width: 700px) {
    .clusters {
      gap: var(--space-4) var(--space-6);
      padding-left: 0;
    }
    .item { --item-width: 150px; }
    .item--zag { margin-left: 20px; }
    .index-title {
      font-size: clamp(3rem, 18vw, 6rem);
      left: var(--space-4);
      bottom: 4vh;
    }
  }
</style>
