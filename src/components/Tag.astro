---
interface Props {
  label: string;
}

const { label } = Astro.props;
---
<span class="tag">{label}</span>

<style>
  .tag {
    display: inline-block;
    padding: 0.15rem 0.6rem;
    border: 1px solid var(--ink-faded);
    border-radius: 999px;
    font-family: var(--font-serif);
    font-size: 0.75rem;
    color: var(--ink-faded);
    margin-right: 0.4rem;
  }
</style>
