---
// A colored "tag-style" section header introducing a body of prose.
// Layout is a 2-column grid: label sits on the left, body fills the right.
//
// Use inside MDX posts:
//   <Section color="maroon" label="this is the raw idea i had">
//     ...prose...
//   </Section>

type Color = 'maroon' | 'green' | 'gray' | 'blue' | 'pink';

interface Props {
  color: Color;
  label: string;
  id?: string;
}

const { color, label, id } = Astro.props;
const slug = id ?? label.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
---
<section id={slug} class={`section section--${color}`}>
  <span class="section-label">{label}</span>
  <div class="section-body">
    <slot />
  </div>
</section>

<style>
  .section {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0 1.5rem;
    margin: 0 0 var(--space-3);
  }

  .section-label {
    grid-column: 1;
    align-self: start;
    padding: 0.25rem 0.7rem;
    border-radius: var(--radius-sm);
    color: var(--section-on-color);
    font-family: var(--font-grotezk);
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    white-space: nowrap;
  }

  .section--maroon .section-label { background: var(--section-maroon); }
  .section--green  .section-label { background: var(--section-green); }
  .section--gray   .section-label { background: var(--section-gray);  color: var(--ink); }
  .section--blue   .section-label { background: var(--section-blue); }
  .section--pink   .section-label { background: var(--section-pink);  color: var(--ink); }

  .section-body {
    grid-column: 2;
  }

  .section-body :global(p) {
    margin: 0 0 0.4rem;
  }

  .section-body :global(p:last-child) {
    margin-bottom: 0;
  }

  /* Stack on narrow viewports — label above body */
  @media (max-width: 700px) {
    .section {
      grid-template-columns: 1fr;
      gap: var(--space-1) 0;
      margin-bottom: var(--space-4);
    }
    .section-label { justify-self: start; }
  }
</style>
